{
	"$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**/src/**/*",
			"**/.vscode/**/*",
			"**/index.html",
			"**/vite.config.ts",
			"!**/src/routeTree.gen.ts",
			"!**/src/styles.css"
		]
	},
	"formatter": {
		"enabled": true,
		"lineWidth": 120,
		"indentStyle": "tab"
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"identifierOrder": "lexicographic",
						"groups": [
							["react", "react/**"],
							["react-dom", "react-dom/**"],
							["vite", "vite/**", "vite-/**"],
							["@vite", "@vite/**"],
							":BLANK_LINE:",
							":ALIAS:",
							"@findrey/**",
							":BLANK_LINE:",
							"@/**",
							":BLANK_LINE:",
							[":PACKAGE:", ":URL:"],
							"DASHBOARD",
							":BLANK_LINE:",
							":PATH:",
							":BLANK_LINE:"
						]
					}
				}
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"nursery": {}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
